ANTHROPIC_API_KEY=your-anthropic-api-key

CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=hr_policies
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Security
MUSTER_API_KEY=change-me
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=8
ALLOWED_ORIGINS=http://localhost:8000

# Gmail inbox
GMAIL_ADDRESS=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_USE_INBOX=false

# Sender allowlist (comma-separated; leave empty to allow all)
ALLOWED_SENDERS=

# Polling
POLL_INTERVAL_SECONDS=60

# Public URL for clickable document links in email replies
# Local dev with ngrok: set NGROK_AUTH_TOKEN and the tunnel starts automatically
# Railway / production: set PUBLIC_BASE_URL to your Railway app URL (e.g. https://muster-production.up.railway.app)
#   and leave NGROK_AUTH_TOKEN empty
PUBLIC_BASE_URL=http://localhost:8000
NGROK_AUTH_TOKEN=

# Microsoft 365 (optional)
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_MAILBOX=
MS365_REDIRECT_URI=http://localhost:8000/ms365/callback
MS365_USE_REAL_INBOX=false
